# Copy this to /etc/bustaudio.env and fill in your values, then:
#   sudo chmod 600 /etc/bustaudio.env
# systemd loads these into the addon's environment on boot.

PORT=7000

# Your private Jackett (so users only need their TorBox key):
JACKETT_URL=http://127.0.0.1:9117
JACKETT_API_KEY=replace_with_your_jackett_key

# Access gate: a comma-separated list of tokens. Anyone using this instance must
# put one of these in their install URL (they enter it on the configure page).
# Give each friend their own so you can revoke one without affecting the rest.
# Leave blank/absent to disable the gate (open instance).
ACCESS_TOKENS=changeme-friend1,changeme-friend2

# Optional: force instant-only for everyone (1 = on)
INSTANT_ONLY=
