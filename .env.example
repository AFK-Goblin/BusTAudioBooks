# Port the addon listens on (default 7000)
PORT=7000

# --- Shared-instance search (so friends only need their TorBox key) ---
# Set these to YOUR Jackett so every user of this instance gets search without
# configuring anything. When set, the configure page hides the source fields.
JACKETT_URL=http://127.0.0.1:9117
JACKETT_API_KEY=

# Alternatively (or additionally) provide a default AudiobookBay domain for the
# built-in scraper. Also makes the configure page hide the source fields.
ABB_DOMAIN=

# Force instant-only mode for every install served by this instance (1 = on).
INSTANT_ONLY=

# Access gate: comma-separated tokens users must include (via the configure page)
# to use this instance. Give each friend their own so you can revoke individually.
# Leave blank to keep the instance open.
ACCESS_TOKENS=

# Native app update prompt: when you publish a new APK, set these so the app can
# show users a "new version available" banner. (JS/UI updates go out via EAS
# Update OTA and don't need these.)
APP_LATEST_VERSION=
APP_APK_URL=
APP_MIN_VERSION=
